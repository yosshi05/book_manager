<div class="max-w-6xl mx-auto px-4 py-8">
  <div class="flex flex-col md:flex-row md:items-center md:justify-between border-b border-gray-200 pb-5 mb-8">
<div>
      <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">書籍管理ライブラリ</h1>
      <p class="mt-2 text-sm text-gray-500">読書の進捗やメモをスマートに記録・管理します。</p>
    </div>
    
    <div class="mt-4 md:mt-0 flex items-center space-x-3">
      
      <%= link_to "ログアウト", destroy_user_session_path, data: { turbo_method: :delete }, class: "text-sm font-medium text-gray-500 hover:text-gray-700 mr-2" %>
      <%= link_to books_path(format: :xlsx), class: "inline-flex items-center px-4 py-2 border border-green-600 rounded-md shadow-sm text-sm font-medium text-green-700 bg-white hover:bg-green-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition" do %>
        <svg class="-ml-1 mr-2 h-5 w-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        Excelにエクスポート
      <% end %>

      <%= link_to new_book_path, class: "inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition" do %>
        <svg class="-ml-1 mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        新しい書籍を登録
      <% end %>

    </div>
  </div>

  <div class="bg-white shadow overflow-hidden sm:rounded-lg border border-gray-200">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200 text-left">
        <thead class="bg-gray-50 text-xs font-semibold text-gray-500 uppercase tracking-wider">
          <tr>
            <th class="px-6 py-4">タイトル</th>
            <th class="px-6 py-4">著者</th>
            <th class="px-6 py-4">ステータス</th>
            <th class="px-6 py-4">進捗</th>
            <th class="px-6 py-4">メモ</th>
            <th class="px-6 py-4 text-right">アクション</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200 text-sm text-gray-600">
          <% @books.each do |book| %>
            <tr class="hover:bg-gray-50 transition">
              <td class="px-6 py-4 font-medium text-gray-900 whitespace-nowrap"><%= book.title %></td>
              <td class="px-6 py-4 whitespace-nowrap text-gray-500"><%= book.author.presence || "—" %></td>
              <td class="px-6 py-4 whitespace-nowrap">
                <% case book.status %>
                <% when "読了" %>
                  <span class="px-2.5 py-1 text-xs font-medium rounded-full bg-green-100 text-green-800">読了</span>
                <% when "読書中" %>
                  <span class="px-2.5 py-1 text-xs font-medium rounded-full bg-amber-100 text-amber-800">読書中</span>
                <% else %>
                  <span class="px-2.5 py-1 text-xs font-medium rounded-full bg-gray-100 text-gray-800">未読</span>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="flex items-center space-x-2">
                  <div class="w-16 bg-gray-200 rounded-full h-2">
                    <div class="bg-indigo-600 h-2 rounded-full" style="width: <%= [book.progress.to_i, 100].min %>%"></div>
                  </div>
                  <span class="text-xs font-semibold text-gray-700"><%= book.progress.to_i %>%</span>
                </div>
              </td>
              <td class="px-6 py-4 max-w-xs truncate text-gray-400"><%= book.memo.presence || "なし" %></td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium space-x-3">
                <%= link_to "詳細", book_path(book), class: "text-indigo-600 hover:text-indigo-900" %>
                <%= link_to "編集", edit_book_path(book), class: "text-amber-600 hover:text-amber-900" %>
                <%= link_to "削除", book_path(book), data: { turbo_method: :delete, confirm: "本当に削除しますか？" }, class: "text-red-600 hover:text-red-900" %>
              </td>
            </tr>
          <% end %>
          <% if @books.empty? %>
            <tr>
              <td colspan="6" class="px-6 py-12 text-center text-gray-400">
                登録されている書籍がありません。「新しい書籍を登録」から追加してみましょう！
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>